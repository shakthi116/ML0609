# Movie Ticket Booking System

print("----- Movie Ticket Booking System -----")

# Input
customer_name = input("Enter Customer Name: ")
seats = int(input("Enter Number of Seats: "))

print("\nSelect Seat Category")
print("1. Silver (Rs.150 per seat)")
print("2. Gold   (Rs.250 per seat)")
print("3. Platinum (Rs.400 per seat)")

choice = int(input("Enter your choice (1-3): "))

# Set ticket price
if choice == 1:
    category = "Silver"
    price = 150
elif choice == 2:
    category = "Gold"
    price = 250
elif choice == 3:
    category = "Platinum"
    price = 400
else:
    print("Invalid Choice!")
    exit()

# Calculate total amount
total = seats * price

# Apply discount
if total >= 2000:
    discount = total * 0.20      # 20% Discount
elif total >= 1000:
    discount = total * 0.10      # 10% Discount
else:
    discount = 0

# Final amount
final_amount = total - discount

# Display Bill
print("\n----- Ticket Booking Bill -----")
print("Customer Name :", customer_name)
print("Seat Category :", category)
print("Number of Seats :", seats)
print("Ticket Cost   : Rs.", total)
print("Discount      : Rs.", discount)
print("Final Amount  : Rs.", final_amount)

print("\nBooking Confirmed! Enjoy Your Movie.")
