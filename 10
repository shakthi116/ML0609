# Railway Ticket Fare Calculator

print("----- Railway Ticket Fare Calculator -----")

# Input
passenger_name = input("Enter Passenger Name: ")
age = int(input("Enter Age: "))

print("\nSelect Travel Class")
print("1. Sleeper")
print("2. AC")
choice = int(input("Enter your choice (1 or 2): "))

# Set base fare
if choice == 1:
    class_name = "Sleeper"
    fare = 500
elif choice == 2:
    class_name = "AC"
    fare = 1000
else:
    print("Invalid Choice!")
    exit()

# Apply concession
if age < 5:
    discount = fare        # 100% concession
elif age <= 12:
    discount = fare * 0.50 # 50% concession
elif age >= 60:
    discount = fare * 0.30 # 30% concession
else:
    discount = 0

# Calculate final fare
final_fare = fare - discount

# Display Ticket Details
print("\n----- Ticket Details -----")
print("Passenger Name :", passenger_name)
print("Age            :", age)
print("Travel Class   :", class_name)
print("Base Fare      : Rs.", fare)
print("Discount       : Rs.", discount)
print("Final Fare     : Rs.", final_fare)
